{
  "name": "arc-agent-pay",
  "version": "1.0.0",
  "description": "AI Agent escrow payments on Arc testnet using ERC-8183",
  "scripts": {
    "compile": "hardhat compile",
    "demo": "hardhat run scripts/deploy-local.ts",
    "demo:full": "hardhat run scripts/demo-full.ts",
    "deploy:arc": "hardhat run scripts/deploy.ts --network arcTestnet",
    "wallets": "npx tsx scripts/generate-wallets.ts",
    "deploy:pipeline": "hardhat run scripts/deploy-pipeline.ts --network arcTestnet",
    "pipeline:run": "npx tsx scripts/agents/pipeline-run-all.ts",
    "pipeline:client": "npx tsx scripts/agents/pipeline-client.ts",
    "pipeline:worker": "npx tsx scripts/agents/pipeline-worker.ts",
    "pipeline:evaluator": "npx tsx scripts/agents/pipeline-evaluator.ts"
  },
  "keywords": [
    "arc",
    "testnet",
    "ai-agent",
    "escrow",
    "erc-8183",
    "usdc"
  ],
  "author": "havelaw",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@types/node": "^25.8.0",
    "forge-std": "github:foundry-rs/forge-std#v1.9.6",
    "hardhat": "^3.4.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@openzeppelin/contracts": "^5.6.1",
    "dotenv": "^17.4.2",
    "ethers": "^6.16.0"
  },
  "type": "module"
}
